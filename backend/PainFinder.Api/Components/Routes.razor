@using PainFinder.Web.Layout
@using PainFinder.Web.Pages
@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(PainFinder.Web.Pages.Dashboard).Assembly"
        AdditionalAssemblies="new[] { typeof(PainFinder.Web.Pages.Dashboard).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <PainFinder.Web.Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>
