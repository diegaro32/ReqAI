@{
    var cfg = SourceConfig.GetValueOrDefault(Name, new("globe", "text-txt-muted"));
}

<span class="inline-flex items-center gap-1 @cfg.Color">
    <Icon Name="@cfg.Icon" Size="@Size" StrokeWidth="1.5" />
    @if (ShowLabel)
    {
        <span class="text-xs text-txt-secondary">@Name</span>
    }
</span>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public bool ShowLabel { get; set; } = true;
    [Parameter] public int Size { get; set; } = 14;

    private record SourceCfg(string Icon, string Color);

    private static readonly Dictionary<string, SourceCfg> SourceConfig = new()
    {
        ["Reddit"]        = new("message-circle", "text-orange-400"),
        ["HackerNews"]    = new("hash",           "text-orange-300"),
        ["StackOverflow"] = new("code-2",         "text-amber-400"),
        ["Twitter"]       = new("message-circle", "text-sky-400"),
        ["AppStore"]      = new("smartphone",     "text-blue-400"),
        ["GooglePlay"]    = new("smartphone",     "text-green-400"),
        ["IndieHackers"]  = new("globe",          "text-blue-300"),
        ["ProductHunt"]   = new("star",           "text-orange-400"),
        ["G2"]            = new("star",           "text-red-400"),
        ["Capterra"]      = new("star",           "text-blue-400"),
        ["Trustpilot"]    = new("star",           "text-green-400"),
        ["Facebook"]      = new("message-circle", "text-blue-500"),
        ["LinkedIn"]      = new("message-circle", "text-blue-400"),
        ["YouTube"]       = new("message-circle", "text-red-500"),
        ["Instagram"]     = new("message-circle", "text-pink-400"),
        ["GitHub"]        = new("code-2",         "text-purple-400"),
    };
}
