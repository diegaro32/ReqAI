@{
    var scheme = ColorMap[Color];
    var iconName = LucideIcon ?? "activity";
}

<div class="glass-card @scheme.Glow p-5 bg-gradient-to-br @scheme.Gradient to-transparent">
    <div class="flex items-start justify-between">
        <div>
            <dd class="text-3xl font-bold tracking-tight @scheme.Text">
                @Value.ToString("N0")
            </dd>
            <dt class="text-[13px] font-medium text-txt-secondary mt-1">@Label</dt>
        </div>
        <div class="w-10 h-10 rounded-xl bg-surface-bg/60 flex items-center justify-center">
            <Icon Name="@iconName" Size="20" Class="@scheme.IconColor" StrokeWidth="1.5" />
        </div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public string? LucideIcon { get; set; }
    [Parameter] public string Color { get; set; } = "default";

    private record ColorScheme(string Text, string Glow, string IconColor, string Gradient);

    private static readonly Dictionary<string, ColorScheme> ColorMap = new()
    {
        ["default"]     = new("text-txt-primary",         "",               "text-txt-muted",             "from-surface-hover/80"),
        ["pain"]        = new("text-semantic-pain",        "glow-pain",      "text-semantic-pain",         "from-semantic-pain/5"),
        ["cluster"]     = new("text-semantic-cluster",     "glow-cluster",   "text-semantic-cluster",      "from-semantic-cluster/5"),
        ["opportunity"] = new("text-semantic-opportunity",  "glow-opportunity","text-semantic-opportunity", "from-semantic-opportunity/5"),
        ["system"]      = new("text-semantic-system",      "",               "text-semantic-system",       "from-semantic-system/5"),
        ["highlight"]   = new("text-semantic-highlight",   "glow-highlight", "text-semantic-highlight",    "from-semantic-highlight/5"),
    };
}
