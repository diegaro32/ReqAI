@implements IDisposable

<div class="flex flex-col items-center justify-center py-12 gap-5">
    <div class="relative w-24 h-24 flex items-center justify-center">
        <div class="absolute inset-0 rounded-full border border-semantic-system/30 radar-ring"></div>
        <div class="absolute inset-0 rounded-full border border-semantic-highlight/20 radar-ring-delayed"></div>
        <div class="absolute inset-0 rounded-full border border-semantic-system/10 radar-ring-delayed-2"></div>
        <div class="relative z-10 w-10 h-10 rounded-full bg-semantic-system/10 flex items-center justify-center">
            <Icon Name="radar" Size="20" Class="text-semantic-system" StrokeWidth="1.5" />
        </div>
    </div>
    <div class="text-center">
        <p class="text-sm font-medium text-txt-primary">@Message</p>
        <p class="text-[11px] text-txt-muted mt-1">La IA está estructurando la conversación en segundo plano</p>
        <p class="text-[12px] text-semantic-highlight font-medium mt-3 animate-pulse">@_statusText</p>
    </div>
</div>

@code {
    [Parameter] public string Message { get; set; } = "Analizando conversación...";

    private string _statusText = "Leyendo la conversación...";
    private System.Threading.Timer? _timer;
    private int _stepIndex;

    private static readonly string[] StatusSteps =
    [
        "Leyendo la conversación...",
        "Extrayendo requerimientos...",
        "Detectando reglas de negocio...",
        "Identificando inconsistencias...",
        "Priorizando alcance del MVP...",
        "Preparando la especificación...",
        "Ya casi..."
    ];

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(_ =>
        {
            _stepIndex = (_stepIndex + 1) % StatusSteps.Length;
            _statusText = StatusSteps[_stepIndex];
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(4));
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
