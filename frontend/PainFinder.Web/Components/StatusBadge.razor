@{
    var dotColor = LiveDot.GetValueOrDefault(Status);
    var style = Styles.GetValueOrDefault(Status, "bg-txt-muted/15 text-txt-muted");
}

<span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide @style">
    @if (dotColor is not null)
    {
        <span class="w-1.5 h-1.5 rounded-full @dotColor pulse-dot"></span>
    }
    @Status
</span>

@code {
    [Parameter] public string Status { get; set; } = "";

    private static readonly Dictionary<string, string> Styles = new()
    {
        ["Completed"] = "bg-semantic-opportunity/15 text-semantic-opportunity ring-1 ring-semantic-opportunity/20",
        ["Running"]   = "bg-semantic-highlight/15 text-semantic-highlight ring-1 ring-semantic-highlight/20",
        ["Scraping"]  = "bg-semantic-highlight/15 text-semantic-highlight ring-1 ring-semantic-highlight/20",
        ["Analyzing"] = "bg-semantic-cluster/15 text-semantic-cluster ring-1 ring-semantic-cluster/20",
        ["Pending"]   = "bg-semantic-cluster/15 text-semantic-cluster ring-1 ring-semantic-cluster/20",
        ["Failed"]    = "bg-semantic-pain/15 text-semantic-pain ring-1 ring-semantic-pain/20",
        ["Active"]    = "bg-semantic-opportunity/15 text-semantic-opportunity ring-1 ring-semantic-opportunity/20",
        ["Paused"]    = "bg-semantic-cluster/15 text-semantic-cluster ring-1 ring-semantic-cluster/20",
        ["Archived"]  = "bg-txt-muted/15 text-txt-muted ring-1 ring-txt-muted/20",
    };

    private static readonly Dictionary<string, string> LiveDot = new()
    {
        ["Running"]   = "bg-semantic-highlight",
        ["Scraping"]  = "bg-semantic-highlight",
        ["Analyzing"] = "bg-semantic-cluster",
        ["Active"]    = "bg-semantic-opportunity",
    };
}
