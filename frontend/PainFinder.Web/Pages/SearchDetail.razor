@page "/search/{Id:guid}"
@inject IJSRuntime JS

<AuthGuard>
    @if (_loading || _run is null)
    {
        <div class="flex items-center gap-3 text-txt-secondary">
            <div class="w-5 h-5 border-2 border-semantic-system/30 border-t-semantic-system rounded-full animate-spin"></div>
            <span>Cargando...</span>
        </div>
    }
    else
    {
        @* Header *@
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-4">
                <a href="/search" class="text-txt-muted hover:text-semantic-highlight transition-colors">← Atrás</a>
                <h1 class="text-3xl font-bold text-txt-primary">"@_run.Keyword"</h1>
                <StatusBadge Status="@_run.Status" />
            </div>
            <div class="flex items-center gap-2">
                @if (_canExport)
                {
                    <button @onclick="HandleExportAll" disabled="@_exporting"
                            class="flex items-center gap-2 rounded-[10px] bg-semantic-system/10 border border-semantic-system/20 px-4 py-2 text-sm font-semibold text-semantic-system hover:bg-semantic-system/20 disabled:opacity-50 transition-colors">
                        <Icon Name="download" Size="14" StrokeWidth="1.5" />
                        @(_exporting ? "Exportando..." : "Exportar CSV")
                    </button>
                }
                else
                {
                    <a href="/account/upgrade"
                       class="flex items-center gap-2 rounded-[10px] bg-surface-hover/60 border border-surface-border/60 px-4 py-2 text-sm font-medium text-txt-muted hover:text-txt-secondary transition-colors"
                       title="Mejora tu plan para exportar resultados">
                        <Icon Name="lock" Size="14" StrokeWidth="1.5" />
                        Exportar
                    </a>
                }
                <button @onclick="() => _showDeleteConfirm = true" disabled="@_deleting"
                        class="rounded-[10px] bg-semantic-pain px-4 py-2 text-sm font-semibold text-white hover:bg-red-500 disabled:opacity-50 transition-colors">
                    @(_deleting ? "Eliminando..." : "Eliminar búsqueda")
                </button>
            </div>
        </div>

        @* Stats *@
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Fuentes</dt>
                <dd class="mt-1 text-sm font-semibold text-txt-primary">
                    @(string.Join(" · ", _run.Sources.Split(',', StringSplitOptions.TrimEntries)))
                </dd>
            </div>
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Iniciado</dt>
                <dd class="mt-1 text-sm font-semibold text-txt-primary">@_run.StartedAt.ToLocalTime().ToString()</dd>
            </div>
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Documentos</dt>
                <dd class="mt-1 text-2xl font-bold text-txt-primary">@FilteredDocs.Count</dd>
            </div>
            <div class="glass-card glow-pain px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Señales Detectadas</dt>
                <dd class="mt-1 text-2xl font-bold text-semantic-pain">@FilteredPains.Count</dd>
            </div>
            <div class="glass-card glow-cluster px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Clusters</dt>
                <dd class="mt-1 text-2xl font-bold text-semantic-cluster">@_clusters.Count</dd>
            </div>
            <div class="glass-card glow-opportunity px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Oportunidades</dt>
                <dd class="mt-1 text-2xl font-bold text-semantic-opportunity">@_allOpportunities.Count</dd>
            </div>
            @if (ExpandedQueryList.Count > 0)
            {
                <button @onclick="() => _queriesExpanded = !_queriesExpanded"
                        class="glass-card px-5 py-5 text-left hover:border-semantic-highlight/40 transition-colors group">
                    <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider flex items-center gap-1.5">
                        <Icon Name="search" Size="11" StrokeWidth="2" />
                        Queries
                    </dt>
                    <dd class="mt-1 flex items-end justify-between gap-2">
                        <span class="text-2xl font-bold text-semantic-highlight">@ExpandedQueryList.Count</span>
                        <Icon Name="@(_queriesExpanded ? "chevron-up" : "chevron-down")" Size="14" StrokeWidth="2"
                              Class="text-txt-muted group-hover:text-semantic-highlight transition-colors mb-1" />
                    </dd>
                </button>
            }
        </div>

        @* Queries panel *@
        @if (_queriesExpanded && ExpandedQueryList.Count > 0)
        {
            <div class="glass-card p-4 mb-4 space-y-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2 text-[12px] font-semibold text-txt-secondary">
                        <Icon Name="search" Size="14" StrokeWidth="1.5" />
                        <span>Queries analizadas</span>
                        <span class="px-1.5 py-0.5 rounded-full bg-semantic-highlight/10 text-semantic-highlight text-[10px] font-bold">@ExpandedQueryList.Count</span>
                    </div>
                    <button @onclick="() => _queriesExpanded = false" class="text-txt-muted hover:text-txt-secondary transition-colors">
                        <Icon Name="x" Size="14" StrokeWidth="2" />
                    </button>
                </div>
                <div class="flex flex-wrap gap-1.5">
                    @foreach (var q in ExpandedQueryList)
                    {
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-surface-hover/60 border border-surface-border/50 text-[11px] text-txt-secondary">
                            <span class="w-1 h-1 rounded-full bg-semantic-highlight/60 shrink-0"></span>
                            @q
                        </span>
                    }
                </div>
            </div>
        }

        @* Filters *@
        <div class="glass-card p-4 mb-4 space-y-3">
            <div class="flex items-center gap-2 text-[12px] font-semibold text-txt-secondary">
                <Icon Name="filter" Size="14" StrokeWidth="1.5" />
                <span>Filtros</span>
                @if (_filterSource is not null || _filterFrom.HasValue || _filterTo.HasValue)
                {
                    <button @onclick="ClearFilters" class="ml-auto text-[11px] text-semantic-system hover:text-semantic-highlight transition-colors">
                        Limpiar todo
                    </button>
                }
            </div>

            <div class="flex flex-wrap items-end gap-3">
                @* Source filter *@
                <div class="flex-1 min-w-[180px]">
                    <label class="block text-[11px] font-medium text-txt-muted mb-1">Fuente</label>
                    <select @bind="_filterSource"
                            class="block w-full rounded-lg bg-surface-bg/80 border border-surface-border px-3 py-2 text-[12px] text-txt-primary focus:border-semantic-highlight focus:ring-1 focus:ring-semantic-highlight/50 focus:outline-none transition-all">
                        <option value="">Todas las fuentes</option>
                        @foreach (var source in _availableSources)
                        {
                            <option value="@source">@source</option>
                        }
                    </select>
                </div>

                @* Date range *@
                <div>
                    <label class="block text-[11px] font-medium text-txt-muted mb-1">Desde</label>
                    <input type="date" @bind="_filterFrom"
                           class="block w-full rounded-lg bg-surface-bg/80 border border-surface-border px-3 py-2 text-[12px] text-txt-primary focus:border-semantic-highlight focus:ring-1 focus:ring-semantic-highlight/50 focus:outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-[11px] font-medium text-txt-muted mb-1">Hasta</label>
                    <input type="date" @bind="_filterTo"
                           class="block w-full rounded-lg bg-surface-bg/80 border border-surface-border px-3 py-2 text-[12px] text-txt-primary focus:border-semantic-highlight focus:ring-1 focus:ring-semantic-highlight/50 focus:outline-none transition-all" />
                </div>
            </div>
        </div>

        @* Tabs *@
        <div class="border-b border-surface-border/50 mb-6">
            <nav class="flex gap-1 overflow-x-auto">
                <button @onclick="() => _tab = Tab.Docs"
                        class="relative pb-3.5 px-4 text-sm font-semibold transition-all whitespace-nowrap @(_tab == Tab.Docs ? "text-semantic-system" : "text-txt-muted hover:text-txt-secondary")">
                    <span class="flex items-center gap-2">
                        <Icon Name="file-text" Size="15" StrokeWidth="1.5" Class="@(_tab == Tab.Docs ? "text-semantic-system" : "")" />
                        Evidencia (@FilteredDocs.Count)
                    </span>
                    @if (_tab == Tab.Docs)
                    {
                        <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-semantic-system rounded-full tab-glow-system"></div>
                    }
                </button>
                <button @onclick="() => _tab = Tab.Pains"
                        class="relative pb-3.5 px-4 text-sm font-semibold transition-all whitespace-nowrap @(_tab == Tab.Pains ? "text-semantic-pain" : "text-txt-muted hover:text-txt-secondary")">
                    <span class="flex items-center gap-2">
                        <Icon Name="alert-circle" Size="15" StrokeWidth="1.5" Class="@(_tab == Tab.Pains ? "text-semantic-pain" : "")" />
                        Señales de Dolor (@FilteredPains.Count)
                    </span>
                    @if (_tab == Tab.Pains)
                    {
                        <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-semantic-pain rounded-full tab-glow-pain"></div>
                    }
                </button>
                <button @onclick="() => _tab = Tab.Clusters"
                        class="relative pb-3.5 px-4 text-sm font-semibold transition-all whitespace-nowrap @(_tab == Tab.Clusters ? "text-semantic-cluster" : "text-txt-muted hover:text-txt-secondary")">
                    <span class="flex items-center gap-2">
                        <Icon Name="flame" Size="15" StrokeWidth="1.5" Class="@(_tab == Tab.Clusters ? "text-semantic-cluster" : "")" />
                        Clusters de Dolor (@_clusters.Count)
                    </span>
                    @if (_tab == Tab.Clusters)
                    {
                        <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-semantic-cluster rounded-full tab-glow-cluster"></div>
                    }
                </button>
                <button @onclick="() => _tab = Tab.Opportunities"
                        class="relative pb-3.5 px-4 text-sm font-semibold transition-all whitespace-nowrap @(_tab == Tab.Opportunities ? "text-semantic-opportunity" : "text-txt-muted hover:text-txt-secondary")">
                    <span class="flex items-center gap-2">
                        <Icon Name="rocket" Size="15" StrokeWidth="1.5" Class="@(_tab == Tab.Opportunities ? "text-semantic-opportunity" : "")" />
                        Oportunidades (@_allOpportunities.Count)
                    </span>
                    @if (_tab == Tab.Opportunities)
                    {
                        <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-semantic-opportunity rounded-full tab-glow-opportunity"></div>
                    }
                </button>
            </nav>
        </div>

        @* Tab Content *@
        <div class="glass-card p-6">
            @if (_tab == Tab.Clusters)
            {
                @if (_clusters.Count == 0)
                {
                    <p class="text-txt-muted text-sm">Sin clusters generados aún. Aparecen cuando el análisis de dolor se completa.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var cluster in _clusters)
                        {
                            <div class="glass-card glow-cluster p-5">
                                <div class="flex items-center justify-between mb-3">
                                    <div>
                                        <h3 class="font-semibold text-[15px] text-txt-primary">@cluster.Title</h3>
                                        <p class="text-xs text-txt-muted mt-0.5">@cluster.Category · @cluster.DocumentCount menciones</p>
                                    </div>
                                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-bold @(cluster.SeverityScore > 0.7 ? "bg-semantic-pain/15 text-semantic-pain" : cluster.SeverityScore > 0.4 ? "bg-semantic-cluster/15 text-semantic-cluster" : "bg-semantic-opportunity/15 text-semantic-opportunity")">
                                        @cluster.SeverityScore.ToString("F2") severidad
                                    </span>
                                </div>
                                <p class="text-[13px] text-txt-secondary leading-relaxed">@cluster.Description</p>
                                <div class="w-full bg-surface-bg/80 rounded-full h-1.5 mt-3">
                                    <div class="h-1.5 rounded-full bg-gradient-to-r from-semantic-cluster to-semantic-pain transition-all"
                                         style="width: @((cluster.SeverityScore * 100).ToString("F0"))%"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else if (_tab == Tab.Opportunities)
            {
                @if (_allOpportunities.Count == 0)
                {
                    <p class="text-txt-muted text-sm">Sin oportunidades identificadas aún. Realiza una búsqueda primero.</p>
                }
                else
                {
                    <div class="space-y-6">
                        @for (var i = 0; i < _allOpportunities.Count; i++)
                        {
                            var opp = _allOpportunities[i];
                            var oppIndex = i + 1;
                            var hasDeepPlan  = _deepAnalyses.TryGetValue(opp.Id, out var deepFilter);
                            var hasPlan      = _mvpPlans.TryGetValue(opp.Id, out var plan);
                            var isRedFlag    = hasDeepPlan && deepFilter!.RedFlag.IsGenericRisk;
                            var showActionPlan = hasPlan || (hasDeepPlan && !isRedFlag);
                            var decisionColor = opp.BuildDecision switch
                            {
                                "STRONG YES" => "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
                                "WEAK YES"   => "bg-yellow-500/15 text-yellow-400 border-yellow-500/30",
                                _            => "bg-semantic-pain/15 text-semantic-pain border-semantic-pain/30"
                            };
                            var decisionIcon = opp.BuildDecision switch
                            {
                                "STRONG YES" => "🟢",
                                "WEAK YES"   => "🟡",
                                _            => "🔴"
                            };

                            <div class="glass-card p-6 bg-gradient-to-br from-semantic-opportunity/[0.03] to-transparent border border-surface-border/40">

                                @* Header: title + build decision badge *@
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex-1 pr-3">
                                        <h3 class="font-bold text-2xl text-txt-primary leading-snug">@oppIndex. @opp.Title</h3>
                                        <p class="text-[12px] text-txt-muted mt-1">@opp.MarketCategory · @opp.ClusterTitle</p>
                                    </div>
                                    <div class="flex flex-col items-end gap-1.5 shrink-0">
                                        @if (!string.IsNullOrEmpty(opp.BuildDecision))
                                        {
                                            <span class="inline-flex items-center gap-1.5 rounded-lg border px-2.5 py-1 text-[11px] font-bold @decisionColor">
                                                @decisionIcon @opp.BuildDecision
                                            </span>
                                        }
                                        <span class="inline-flex items-center gap-1 rounded-full bg-semantic-opportunity/15 text-semantic-opportunity px-2.5 py-1 text-[11px] font-bold">
                                            @((opp.ConfidenceScore * 100).ToString("F0"))% confianza
                                        </span>
                                    </div>
                                </div>

                                @* Build Reasoning *@
                                @if (!string.IsNullOrEmpty(opp.BuildReasoning))
                                {
                                    <p class="text-[12px] text-txt-muted italic mb-4 pl-3 border-l-2 border-surface-border/50">@opp.BuildReasoning</p>
                                }

                                @* Market Reality Score *@
                                @if (opp.MarketRealityScore > 0)
                                {
                                    <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 p-4 mb-4">
                                        <div class="flex items-center justify-between mb-2">
                                            <span class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Puntuación de Realidad de Mercado</span>
                                            <span class="text-[13px] font-bold @(opp.MarketRealityScore >= 0.75 ? "text-emerald-400" : opp.MarketRealityScore >= 0.5 ? "text-yellow-400" : "text-semantic-pain")">
                                                @((opp.MarketRealityScore * 100).ToString("F0"))%
                                            </span>
                                        </div>
                                        <div class="w-full bg-surface-border/40 rounded-full h-1.5 mb-3">
                                            <div class="h-1.5 rounded-full transition-all @(opp.MarketRealityScore >= 0.75 ? "bg-emerald-400" : opp.MarketRealityScore >= 0.5 ? "bg-yellow-400" : "bg-semantic-pain")"
                                                 style="width: @((opp.MarketRealityScore * 100).ToString("F0"))%"></div>
                                        </div>
                                        <div class="grid grid-cols-5 gap-1 text-center">
                                            @{
                                                var factors = new[] {
                                                    ("Dolor", opp.MarketRealityBreakdown.PainIntensity),
                                                    ("Frec", opp.MarketRealityBreakdown.Frequency),
                                                    ("Urgencia", opp.MarketRealityBreakdown.Urgency),
                                                    ("$Intent", opp.MarketRealityBreakdown.MonetizationIntent),
                                                    ("Brecha", opp.MarketRealityBreakdown.CompetitionDensity)
                                                };
                                            }
                                            @foreach (var (label, score) in factors)
                                            {
                                                <div class="rounded-lg bg-surface-bg/80 p-1.5">
                                                    <div class="text-[10px] text-txt-muted mb-0.5">@label</div>
                                                    <div class="text-[12px] font-bold @(score >= 0.7 ? "text-emerald-400" : score >= 0.4 ? "text-yellow-400" : "text-semantic-pain")">
                                                        @((score * 100).ToString("F0"))
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @* ICP *@
                                @if (!string.IsNullOrEmpty(opp.Icp.Role))
                                {
                                    <div class="flex items-start gap-2 mb-4 rounded-lg bg-semantic-cluster/5 border border-semantic-cluster/20 p-3">
                                        <span class="text-semantic-cluster text-[14px] shrink-0 mt-0.5">🎯</span>
                                        <div>
                                            <span class="text-[11px] font-semibold text-semantic-cluster uppercase tracking-wider">ICP</span>
                                            <p class="text-[13px] text-txt-primary font-medium mt-0.5">@opp.Icp.Role</p>
                                            @if (!string.IsNullOrEmpty(opp.Icp.Context))
                                            {
                                                <p class="text-[12px] text-txt-secondary mt-0.5">@opp.Icp.Context</p>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Problem & Solution *@
                                <div class="space-y-3 mb-4">
                                    <div>
                                        <span class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Problema</span>
                                        <p class="text-[13px] text-txt-secondary mt-0.5 leading-relaxed">@opp.ProblemSummary</p>
                                    </div>
                                    <div class="border-l-2 border-semantic-system/30 pl-3">
                                        <span class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Solución Sugerida</span>
                                        <p class="text-[13px] text-semantic-system mt-0.5 leading-relaxed">@opp.SuggestedSolution</p>
                                    </div>
                                </div>

                                @* Evidence Quotes *@
                                @if (opp.Evidence.Count > 0)
                                {
                                    <div class="mb-4">
                                        <span class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider mb-2 block">Evidencia</span>
                                        <div class="space-y-1.5">
                                            @foreach (var quote in opp.Evidence)
                                            {
                                                <div class="rounded-lg bg-semantic-pain/5 border border-semantic-pain/15 px-3 py-2">
                                                    <p class="text-[12px] text-txt-primary italic">"@quote.Quote"</p>
                                                    <p class="text-[10px] text-txt-muted mt-1">@quote.Source · @quote.UserContext</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Competition & Gap *@
                                @if (!string.IsNullOrEmpty(opp.Competition.GapAnalysis) || opp.Competition.ToolsDetected.Count > 0)
                                {
                                    <div class="rounded-lg bg-surface-bg/60 border border-surface-border/30 p-3 mb-4">
                                        <span class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Competencia y Brecha</span>
                                        @if (opp.Competition.ToolsDetected.Count > 0)
                                        {
                                            <div class="flex flex-wrap gap-1.5 mt-2">
                                                @foreach (var tool in opp.Competition.ToolsDetected)
                                                {
                                                    <span class="inline-flex items-center rounded-full bg-surface-bg border border-surface-border/60 text-txt-muted px-2 py-0.5 text-[11px]">@tool</span>
                                                }
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(opp.Competition.GapAnalysis))
                                        {
                                            <p class="text-[12px] text-txt-secondary mt-2 leading-relaxed">@opp.Competition.GapAnalysis</p>
                                        }
                                    </div>
                                }

                                @* ── Deep Opportunity Analysis ── *@
                                <div class="pt-3 border-t border-surface-border/30">
                                    @if (_generatingDeep.Contains(opp.Id))
                                    {
                                        <div class="flex items-center gap-3 text-txt-secondary text-sm py-3">
                                            <div class="w-4 h-4 border-2 border-purple-500/30 border-t-purple-400 rounded-full animate-spin shrink-0"></div>
                                            <span>Analizando oportunidad en profundidad...</span>
                                        </div>
                                    }
                                    else if (_deepErrors.Contains(opp.Id))
                                    {
                                        <div class="flex items-center justify-between">
                                            <p class="text-[13px] text-semantic-pain">Error al generar el análisis. Inténtalo de nuevo.</p>
                                            <button @onclick="() => GenerateDeepAnalysisAsync(opp)"
                                                    class="text-[12px] font-medium text-purple-400 bg-purple-500/8 hover:bg-purple-500/15 px-3 py-1.5 rounded-lg transition-colors">
                                                ↺ Reintentar
                                            </button>
                                        </div>
                                    }
                                    else if (_deepAnalyses.TryGetValue(opp.Id, out var deep))
                                    {
                                        <div class="space-y-4">
                                            <h4 class="text-[13px] font-bold text-purple-400 flex items-center gap-2">
                                                <span>🔬</span> Análisis Profundo de Oportunidad
                                            </h4>

                                            @* 1. Dolor específico *@
                                            <div class="rounded-xl bg-semantic-pain/5 border border-semantic-pain/20 p-3">
                                                <span class="text-[10px] font-bold text-semantic-pain uppercase tracking-wider">💥 Dolor Específico</span>
                                                <p class="text-[13px] text-txt-primary mt-1 italic">"@deep.SpecificPain"</p>
                                            </div>

                                            @* 2. Contexto operativo *@
                                            <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 p-3">
                                                <span class="text-[10px] font-bold text-txt-muted uppercase tracking-wider">🎯 Contexto Operativo</span>
                                                <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 mt-2 text-[12px]">
                                                    <div><span class="text-txt-muted">Canal:</span> <span class="text-txt-primary">@deep.OperativeContext.Channel</span></div>
                                                    <div><span class="text-txt-muted">Momento:</span> <span class="text-txt-primary">@deep.OperativeContext.Timing</span></div>
                                                    <div><span class="text-txt-muted">Usuario:</span> <span class="text-txt-primary">@deep.OperativeContext.AffectedUser</span></div>
                                                    <div><span class="text-txt-muted">Frecuencia:</span> <span class="text-txt-primary">@deep.OperativeContext.Frequency</span></div>
                                                    <div class="col-span-2"><span class="text-txt-muted">Consecuencia:</span> <span class="text-semantic-pain">@deep.OperativeContext.DirectConsequence</span></div>
                                                </div>
                                            </div>

                                            @* 3. Solución actual imperfecta *@
                                            <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 p-3 space-y-2">
                                                <span class="text-[10px] font-bold text-txt-muted uppercase tracking-wider">🧱 Solución Actual (Imperfecta)</span>
                                                <div class="flex flex-wrap gap-1.5 mt-1">
                                                    @foreach (var tool in deep.CurrentSolution.ToolsUsed)
                                                    {
                                                        <span class="px-2 py-0.5 rounded-full bg-surface-bg border border-surface-border/60 text-txt-muted text-[11px]">@tool</span>
                                                    }
                                                </div>
                                                <p class="text-[12px]"><span class="text-emerald-400 font-medium">✓ Funciona:</span> <span class="text-txt-secondary">@deep.CurrentSolution.WhatWorks</span></p>
                                                <p class="text-[12px]"><span class="text-semantic-pain font-medium">✗ Falla:</span> <span class="text-txt-secondary">@deep.CurrentSolution.WhatFails</span></p>
                                            </div>

                                            @* 4. Brecha real + 5. Wedge *@
                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                                <div class="rounded-xl bg-yellow-500/5 border border-yellow-500/20 p-3">
                                                    <span class="text-[10px] font-bold text-yellow-400 uppercase tracking-wider">⚔️ Brecha Real</span>
                                                    <p class="text-[12px] text-txt-secondary mt-1 leading-relaxed">@deep.OpportunityGap</p>
                                                </div>
                                                <div class="rounded-xl bg-purple-500/5 border border-purple-500/20 p-3">
                                                    <span class="text-[10px] font-bold text-purple-400 uppercase tracking-wider">🧠 Wedge (Ángulo de Entrada)</span>
                                                    <p class="text-[13px] text-txt-primary font-semibold mt-1">@deep.Wedge.Statement</p>
                                                    <p class="text-[11px] text-txt-muted mt-1">@deep.Wedge.Justification</p>
                                                </div>
                                            </div>

                                            @* 6. Propuesta de valor *@
                                            <div class="rounded-xl bg-emerald-500/5 border border-emerald-500/20 p-3">
                                                <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-wider">🚀 Propuesta de Valor</span>
                                                <p class="text-[13px] text-emerald-300 font-semibold mt-1">@deep.ValueProposition</p>
                                            </div>

                                            @* 7. Acción inmediata + 8. Test de validación *@
                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                                <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 p-3 space-y-1.5">
                                                    <span class="text-[10px] font-bold text-txt-muted uppercase tracking-wider">⚡ Acción Inmediata</span>
                                                    <p class="text-[12px]"><span class="text-txt-muted">¿A quién?</span> <span class="text-txt-primary">@deep.ImmediateAction.WhoToContact</span></p>
                                                    <p class="text-[12px]"><span class="text-txt-muted">¿Dónde?</span> <span class="text-txt-primary">@deep.ImmediateAction.WhereToFind</span></p>
                                                    <p class="text-[12px] mt-1 italic text-txt-secondary border-l-2 border-surface-border/50 pl-2">@deep.ImmediateAction.WhatToSay</p>
                                                </div>
                                                <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 p-3 space-y-1.5">
                                                    <span class="text-[10px] font-bold text-txt-muted uppercase tracking-wider">🧪 Test de Validación</span>
                                                    <p class="text-[12px]"><span class="text-txt-muted">Servicio manual:</span> <span class="text-txt-primary">@deep.ValidationTest.ManualService</span></p>
                                                    <p class="text-[12px]"><span class="text-txt-muted">Entregable:</span> <span class="text-txt-primary">@deep.ValidationTest.ResultToDeliver</span></p>
                                                    <p class="text-[12px]"><span class="text-txt-muted">Medir:</span> <span class="text-semantic-opportunity">@deep.ValidationTest.WhatToMeasure</span></p>
                                                </div>
                                            </div>

                                            @* 9. MVP + 10. Disparador de pago *@
                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                                <div class="rounded-xl bg-semantic-highlight/5 border border-semantic-highlight/20 p-3">
                                                    <span class="text-[10px] font-bold text-semantic-highlight uppercase tracking-wider">🧩 MVP Correcto</span>
                                                    <p class="text-[12px] text-txt-primary mt-1">1. @deep.MvpDefinition.Feature1</p>
                                                    @if (!string.IsNullOrEmpty(deep.MvpDefinition.Feature2) && deep.MvpDefinition.Feature2 != "N/A")
                                                    {
                                                        <p class="text-[12px] text-txt-secondary mt-0.5">2. @deep.MvpDefinition.Feature2</p>
                                                    }
                                                </div>
                                                <div class="rounded-xl bg-semantic-opportunity/5 border border-semantic-opportunity/20 p-3">
                                                    <span class="text-[10px] font-bold text-semantic-opportunity uppercase tracking-wider">💰 Disparador de Pago</span>
                                                    <p class="text-[12px] text-txt-secondary mt-1 leading-relaxed">@deep.PaymentTrigger</p>
                                                </div>
                                            </div>

                                            @* 11. Red Flag *@
                                            @if (deep.RedFlag.IsGenericRisk)
                                            {
                                                <div class="rounded-xl bg-semantic-pain/8 border border-semantic-pain/25 p-3">
                                                    <span class="text-[10px] font-bold text-semantic-pain uppercase tracking-wider">🧨 Red Flag — Oportunidad genérica</span>
                                                    <p class="text-[12px] text-semantic-pain/80 mt-1">@deep.RedFlag.Explanation</p>
                                                    <p class="text-[12px] text-txt-secondary mt-1"><span class="font-medium">Cómo especificar más:</span> @deep.RedFlag.HowToMakeSpecific</p>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <button @onclick="() => GenerateDeepAnalysisAsync(opp)"
                                                class="flex items-center gap-2 text-[13px] font-semibold text-purple-400 bg-purple-500/8 hover:bg-purple-500/15 px-4 py-2.5 rounded-xl transition-colors border border-purple-500/20 hover:border-purple-500/40">
                                            <span>🔬</span>
                                            <span>Análisis Profundo de Oportunidad</span>
                                        </button>
                                    }
                                </div>

                                @* ── Plan de Acción (SEGUNDO — solo visible tras análisis profundo) ── *@
                                @if (showActionPlan)
                                {
                                <div class="pt-3 border-t border-surface-border/20 mt-2">
                                    @if (_generatingMvp.Contains(opp.Id))
                                    {
                                        <div class="flex items-center gap-3 text-txt-secondary text-sm py-3">
                                            <div class="w-4 h-4 border-2 border-semantic-highlight/30 border-t-semantic-highlight rounded-full animate-spin shrink-0"></div>
                                            <span>Nuestros agentes están creando tu plan de acción...</span>
                                        </div>
                                    }
                                    else if (_mvpErrors.Contains(opp.Id))
                                    {
                                        <div class="flex items-center justify-between">
                                            <p class="text-[13px] text-semantic-pain">Error al generar el plan. Inténtalo de nuevo.</p>
                                            <button @onclick="() => GenerateMvpAsync(opp)"
                                                    class="text-[12px] font-medium text-semantic-highlight bg-semantic-highlight/8 hover:bg-semantic-highlight/15 px-3 py-1.5 rounded-lg transition-colors">
                                                ↺ Reintentar
                                            </button>
                                        </div>
                                    }
                                    else if (hasPlan)
                                    {
                                        <div class="space-y-4">
                                            <div class="flex items-center justify-between">
                                                <h4 class="text-[13px] font-bold text-semantic-highlight">⚡ Plan de Acción</h4>
                                                <button @onclick="() => { _mvpPlans.Remove(opp.Id); _mvpErrors.Remove(opp.Id); }"
                                                        class="text-[11px] text-txt-muted hover:text-txt-secondary transition-colors">
                                                    Regenerar
                                                </button>
                                            </div>

                                            @* Action Block — most important, shown first *@
                                            @if (plan!.Action is { } action)
                                            {
                                                <div class="rounded-xl border border-semantic-highlight/25 bg-semantic-highlight/[0.04] p-4 space-y-3">
                                                    <div class="rounded-lg bg-semantic-highlight/10 border border-semantic-highlight/30 p-3">
                                                        <span class="text-[10px] font-bold text-semantic-highlight uppercase tracking-wider">⚡ Haz Esto Mañana a las 9am</span>
                                                        <p class="text-[13px] text-txt-primary font-medium mt-1 leading-relaxed">@action.FirstStepTomorrow</p>
                                                    </div>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">ICP Exacto a Contactar</span>
                                                            <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@action.ExactIcp</p>
                                                        </div>
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Propuesta de Valor</span>
                                                            <p class="text-[12px] text-semantic-system mt-0.5 font-medium leading-relaxed">@action.ValueProposition</p>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Mensaje de Contacto</span>
                                                        <div class="mt-1 rounded-lg bg-surface-bg/80 border border-surface-border/50 p-2.5">
                                                            <p class="text-[12px] text-txt-primary leading-relaxed whitespace-pre-line">@action.OutreachMessage</p>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Test de Validación</span>
                                                        <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@action.ValidationTest</p>
                                                    </div>
                                                </div>
                                            }

                                            @* Monetization Strategies *@
                                            @if (plan!.MonetizationStrategies.Count > 0)
                                            {
                                                <div class="space-y-2 mt-1">
                                                    <span class="text-[10px] font-bold text-semantic-cluster uppercase tracking-wider">💰 Estrategias de Monetización</span>
                                                    <div class="flex flex-wrap gap-2">
                                                        @foreach (var strategy in plan.MonetizationStrategies)
                                                        {
                                                            <div class="flex items-center gap-2 rounded-lg bg-semantic-cluster/5 border border-semantic-cluster/20 px-3 py-1.5">
                                                                <span class="text-[11px] font-medium text-txt-secondary">@strategy.Model</span>
                                                                <span class="text-[12px] font-bold text-semantic-opportunity">@strategy.PriceRange</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @* MVP Plan — secondary detail *@
                                            <details class="group">
                                                <summary class="cursor-pointer text-[12px] font-semibold text-txt-muted hover:text-txt-secondary transition-colors list-none flex items-center gap-1.5">
                                                    <span class="group-open:rotate-90 transition-transform inline-block">▶</span>
                                                    Detalles del Plan MVP
                                                </summary>
                                                <div class="mt-3 rounded-xl bg-surface-bg/60 border border-surface-border/40 p-4 space-y-3">
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Definición del Problema</span>
                                                            <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@plan.ProblemStatement</p>
                                                        </div>
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Usuarios Objetivo</span>
                                                            <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@plan.TargetUsers</p>
                                                        </div>
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Stack Tecnológico</span>
                                                            <p class="text-[12px] text-semantic-system mt-0.5 font-mono">@plan.TechStack</p>
                                                        </div>
                                                        <div>
                                                            <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Cronograma</span>
                                                            <p class="text-[12px] text-semantic-opportunity mt-0.5 font-semibold">@plan.EstimatedTimeline</p>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Funcionalidades Principales</span>
                                                        <ul class="mt-1.5 space-y-1">
                                                            @foreach (var feature in plan.CoreFeatures)
                                                            {
                                                                <li class="flex items-start gap-2 text-[12px] text-txt-secondary">
                                                                    <span class="text-semantic-opportunity mt-0.5 shrink-0">✓</span>
                                                                    @feature
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] font-semibold text-txt-muted uppercase tracking-wider">Estrategia de Validación</span>
                                                        <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@plan.ValidationStrategy</p>
                                                    </div>
                                                </div>
                                            </details>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (isRedFlag)
                                        {
                                            <div class="rounded-xl bg-semantic-pain/8 border border-semantic-pain/25 p-4 space-y-3">
                                                <div class="flex items-start gap-2">
                                                    <span class="text-lg shrink-0">🧨</span>
                                                    <div>
                                                        <p class="text-[13px] font-semibold text-semantic-pain">Oportunidad demasiado amplia</p>
                                                        <p class="text-[12px] text-txt-secondary mt-0.5 leading-relaxed">@deepFilter!.RedFlag.Explanation</p>
                                                    </div>
                                                </div>
                                                <div class="rounded-lg bg-surface-bg/60 border border-surface-border/40 px-3 py-2">
                                                    <p class="text-[11px] text-txt-muted">
                                                        <span class="font-medium text-txt-secondary">👉 Cómo enfocarla:</span> @deepFilter.RedFlag.HowToMakeSpecific
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            @if (_mvpLimitReached)
                                            {
                                                <div class="rounded-xl bg-semantic-pain/10 border border-semantic-pain/20 px-4 py-2.5 text-[12px] text-semantic-pain">
                                                    Alcanzaste el límite de planes de acción en tu plan gratuito. <a href="/account/upgrade" class="font-semibold underline hover:text-semantic-pain/80">Mejora tu plan</a> para obtener más.
                                                </div>
                                            }
                                            <button @onclick="() => GenerateMvpAsync(opp)" disabled="@_mvpLimitReached"
                                                    class="flex items-center gap-2 text-[13px] font-semibold text-semantic-highlight bg-semantic-highlight/8 hover:bg-semantic-highlight/15 px-4 py-2.5 rounded-xl transition-colors border border-semantic-highlight/20 hover:border-semantic-highlight/40 disabled:opacity-50 disabled:cursor-not-allowed">
                                                <span>⚡</span>
                                                <span>Generar Plan de Acción</span>
                                            </button>
                                        }
                                        }
                                        </div>
                                        }

                                    </div>
                        }
                    </div>
                }
            }
            else if (_tab == Tab.Docs)
            {
                @if (FilteredDocs.Count == 0)
                {
                    <p class="text-txt-muted text-sm">Ningún documento coincide con los filtros actuales.</p>
                }
                else
                {
                    <div class="space-y-3">
                        @foreach (var doc in FilteredDocs.Take(_visibleDocs))
                        {
                            <div class="glass-card glow-highlight p-4">
                                <div class="flex justify-between items-start">
                                    <div class="flex-1 min-w-0">
                                        <a href="@doc.Url" target="_blank" rel="noopener noreferrer"
                                           class="font-medium text-semantic-system hover:text-semantic-highlight truncate block transition-colors">
                                            @(string.IsNullOrEmpty(doc.Title) ? "Sin título" : doc.Title)
                                        </a>
                                        <p class="text-sm text-txt-secondary mt-1 line-clamp-2">@(doc.Content.Length > 200 ? doc.Content[..200] + "..." : doc.Content)</p>
                                        <div class="flex gap-4 mt-2.5 meta-data text-txt-muted">
                                            <span>@(string.IsNullOrEmpty(doc.Author) ? "desconocido" : doc.Author)</span>
                                            <span class="text-semantic-highlight/70">@doc.SourceName</span>
                                            <span>@doc.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4 flex flex-col items-center gap-2">
                        <span class="text-[11px] text-txt-muted">Mostrando @Math.Min(_visibleDocs, FilteredDocs.Count) de @FilteredDocs.Count documentos</span>
                        @if (Math.Min(_visibleDocs, FilteredDocs.Count) < FilteredDocs.Count)
                        {
                            <button @onclick="() => _visibleDocs += PageSize"
                                    class="text-[12px] font-medium text-semantic-system hover:text-semantic-highlight bg-semantic-system/8 hover:bg-semantic-system/15 px-4 py-2 rounded-lg transition-colors">
                                Cargar más
                            </button>
                        }
                    </div>
                }
            }
            else if (_tab == Tab.Pains)
            {
                @if (FilteredPains.Count == 0)
                {
                    <p class="text-txt-muted text-sm">Ninguna señal de dolor coincide con los filtros actuales.</p>
                }
                else
                {
                    <div class="grid grid-cols-1 gap-3">
                        @foreach (var signal in FilteredPains.Take(_visiblePains))
                        {
                            <div class="glass-card glow-pain p-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1 min-w-0">
                                        <p class="text-[13px] text-txt-primary leading-relaxed">@signal.PainPhrase</p>
                                        <div class="flex items-center gap-3 mt-2.5">
                                            <span class="inline-flex items-center rounded-lg bg-semantic-pain/10 text-semantic-pain px-2.5 py-1 text-[11px] font-semibold">
                                                @signal.PainCategory
                                            </span>
                                            <span class="meta-data text-txt-muted truncate max-w-[240px]" title="@signal.DocumentTitle">@signal.DocumentTitle</span>
                                        </div>
                                    </div>
                                    <div class="flex flex-col items-end gap-1.5 shrink-0">
                                        <span class="text-lg font-bold @(signal.PainScore > 0.7 ? "text-semantic-pain" : signal.PainScore > 0.4 ? "text-semantic-cluster" : "text-semantic-opportunity")">
                                            @((signal.PainScore * 100).ToString("F0"))
                                        </span>
                                        <div class="w-14 bg-surface-border/40 rounded-full h-1.5">
                                            <div class="h-1.5 rounded-full @(signal.PainScore > 0.7 ? "bg-semantic-pain" : signal.PainScore > 0.4 ? "bg-semantic-cluster" : "bg-semantic-opportunity")"
                                                 style="width: @((signal.PainScore * 100).ToString("F0"))%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4 flex flex-col items-center gap-2">
                        <span class="text-[11px] text-txt-muted">Mostrando @Math.Min(_visiblePains, FilteredPains.Count) de @FilteredPains.Count señales de dolor</span>
                        @if (Math.Min(_visiblePains, FilteredPains.Count) < FilteredPains.Count)
                        {
                            <button @onclick="() => _visiblePains += PageSize"
                                    class="text-[12px] font-medium text-semantic-system hover:text-semantic-highlight bg-semantic-system/8 hover:bg-semantic-system/15 px-4 py-2 rounded-lg transition-colors">
                                Cargar más
                            </button>
                        }
                    </div>
                }
            }
        </div>
    }
</AuthGuard>

@* ── Delete confirmation modal ── *@
@if (_showDeleteConfirm)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4"
         @onclick="() => _showDeleteConfirm = false">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        <div class="relative z-10 w-full rounded-2xl bg-surface-card border border-surface-border/60 shadow-2xl p-6 space-y-5"
             style="max-width: 420px"
             @onclick:stopPropagation>
            <div class="flex items-start gap-3">
                <div class="shrink-0 rounded-xl bg-semantic-pain/15 border border-semantic-pain/25 p-2.5">
                    <Icon Name="trash-2" Size="20" StrokeWidth="1.5" Class="text-semantic-pain" />
                </div>
                <div>
                    <h3 class="text-[15px] font-bold text-txt-primary">¿Eliminar esta búsqueda?</h3>
                    <p class="text-[13px] text-txt-muted mt-1 leading-relaxed">
                        Se eliminarán permanentemente todos los documentos, señales de dolor y oportunidades asociadas.
                        Esta acción no se puede deshacer.
                    </p>
                </div>
            </div>

            @if (_run is not null)
            {
                <div class="rounded-xl bg-surface-bg/60 border border-surface-border/40 px-4 py-3">
                    <p class="text-[12px] font-semibold text-txt-primary truncate">@_run.Keyword</p>
                    <p class="text-[11px] text-txt-muted mt-0.5">
                        @_run.DocumentsCollected docs · @_run.PainsDetected señales · @_run.StartedAt.ToString("dd MMM yyyy")
                    </p>
                </div>
            }

            <div class="flex gap-3 pt-1">
                <button @onclick="() => _showDeleteConfirm = false"
                        class="flex-1 rounded-xl border border-surface-border/60 bg-surface-hover/40 px-4 py-2.5 text-[13px] font-semibold text-txt-secondary hover:bg-surface-hover/70 transition-colors">
                    Cancelar
                </button>
                <button @onclick="HandleDelete" disabled="@_deleting"
                        class="flex-1 rounded-xl bg-semantic-pain px-4 py-2.5 text-[13px] font-semibold text-white hover:bg-red-500 disabled:opacity-60 transition-colors flex items-center justify-center gap-2">
                    @if (_deleting)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                        <span>Eliminando...</span>
                    }
                    else
                    {
                        <span>Sí, eliminar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] public string? InitialTab { get; set; }
    [Inject] private ISearchRunService SearchRunService { get; set; } = default!;
    [Inject] private IMvpGenerationService MvpService { get; set; } = default!;
    [Inject] private IDeepOpportunityService DeepOpportunityService { get; set; } = default!;
    [Inject] private ISubscriptionService SubscriptionService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private AuthService Auth { get; set; } = default!;

    private SearchRunDto? _run;
    private List<RawDocumentDto> _docs = [];
    private List<PainSignalDto> _pains = [];
    private List<PainClusterDto> _clusters = [];
    private List<OpportunityDto> _allOpportunities = [];

    private Dictionary<Guid, MvpPlanDto> _mvpPlans = [];
    private HashSet<Guid> _generatingMvp = [];
    private HashSet<Guid> _mvpErrors = [];
    private bool _mvpLimitReached;

    private Dictionary<Guid, DeepOpportunityAnalysisDto> _deepAnalyses = [];
    private HashSet<Guid> _generatingDeep = [];
    private HashSet<Guid> _deepErrors = [];

    private Tab _tab = Tab.Docs;
    private bool _loading = true;
    private bool _deleting;
    private bool _exporting;
    private bool _canExport;
    private bool _queriesExpanded;
    private bool _showDeleteConfirm;

    private List<string> ExpandedQueryList => string.IsNullOrWhiteSpace(_run?.ExpandedKeywords)
        ? []
        : _run.ExpandedKeywords.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private string? _filterSource;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private List<string> _availableSources = [];

    private const int PageSize = 30;
    private int _visibleDocs = PageSize;
    private int _visiblePains = PageSize;

    private enum Tab { Docs, Pains, Clusters, Opportunities }

    private List<RawDocumentDto> FilteredDocs => _docs
        .Where(d => string.IsNullOrEmpty(_filterSource) || d.SourceName.Equals(_filterSource, StringComparison.OrdinalIgnoreCase))
        .Where(d => !_filterFrom.HasValue || d.CreatedAt.Date >= _filterFrom.Value.Date)
        .Where(d => !_filterTo.HasValue || d.CreatedAt.Date <= _filterTo.Value.Date)
        .ToList();

    private List<PainSignalDto> FilteredPains
    {
        get
        {
            if (string.IsNullOrEmpty(_filterSource) && !_filterFrom.HasValue && !_filterTo.HasValue)
                return _pains;

            var filteredDocTitles = FilteredDocs.Select(d => d.Title).ToHashSet(StringComparer.OrdinalIgnoreCase);
            return _pains.Where(p => filteredDocTitles.Contains(p.DocumentTitle)).ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _run = await SearchRunService.GetSearchRunAsync(Id, Auth.User!.Id);
                _docs = (await SearchRunService.GetSearchRunDocumentsAsync(Id, Auth.User!.Id)).ToList();
                _pains = (await SearchRunService.GetSearchRunPainsAsync(Id, Auth.User!.Id)).ToList();
                _clusters = (await SearchRunService.GetSearchRunClustersAsync(Id, Auth.User!.Id)).ToList();
                _allOpportunities = (await SearchRunService.GetSearchRunOpportunitiesAsync(Id, Auth.User!.Id)).ToList();
                _availableSources = _docs.Select(d => d.SourceName).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();

                // Load persisted action plans
                var oppIds = _allOpportunities.Select(o => o.Id).ToList();
                if (oppIds.Count > 0)
                {
                    _mvpPlans = await MvpService.GetActionPlansForOpportunitiesAsync(oppIds);
                    _deepAnalyses = await DeepOpportunityService.GetDeepAnalysesForOpportunitiesAsync(oppIds);
                }

                // Check export permission
                var plan = await SubscriptionService.GetUserPlanAsync(Auth.User!.Id);
                _canExport = plan.CanExport;

                // Honor ?tab= query param (e.g. from Opportunities page)
                if (!string.IsNullOrEmpty(InitialTab) &&
                    Enum.TryParse<Tab>(InitialTab, ignoreCase: true, out var requestedTab))
                    _tab = requestedTab;
            }
            catch { }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private async Task GenerateMvpAsync(OpportunityDto opp)
    {
        if (_generatingMvp.Contains(opp.Id)) return;
        if (Auth.User is null) return;

        // Check usage limit before generating
        if (!await SubscriptionService.CanUserGenerateMvpAsync(Auth.User.Id))
        {
            _mvpLimitReached = true;
            StateHasChanged();
            return;
        }

        _mvpErrors.Remove(opp.Id);
        _mvpLimitReached = false;
        _generatingMvp.Add(opp.Id);
        StateHasChanged();

        try
        {
            var plan = await MvpService.GenerateMvpPlanAsync(opp);
            _mvpPlans[opp.Id] = plan;

            // Persist to database
            await MvpService.SaveActionPlanAsync(opp.Id, plan);

            // Increment usage counter after successful generation
            await SubscriptionService.IncrementMvpUsageAsync(Auth.User.Id);
        }
        catch
        {
            _mvpErrors.Add(opp.Id);
        }
        finally
        {
            _generatingMvp.Remove(opp.Id);
            StateHasChanged();
        }
    }

    private async Task GenerateDeepAnalysisAsync(OpportunityDto opp)
    {
        if (_generatingDeep.Contains(opp.Id)) return;

        _deepErrors.Remove(opp.Id);
        _generatingDeep.Add(opp.Id);
        StateHasChanged();

        try
        {
            var analysis = await DeepOpportunityService.AnalyzeAsync(opp);
            _deepAnalyses[opp.Id] = analysis;
            await DeepOpportunityService.SaveDeepAnalysisAsync(opp.Id, analysis);
        }
        catch
        {
            _deepErrors.Add(opp.Id);
        }
        finally
        {
            _generatingDeep.Remove(opp.Id);
            StateHasChanged();
        }
    }

    private void ClearFilters()
    {
        _filterSource = null;
        _filterFrom = null;
        _filterTo = null;
        _visibleDocs = PageSize;
        _visiblePains = PageSize;
    }

    private async Task HandleDelete()
    {
        _deleting = true;
        try
        {
            await SearchRunService.DeleteSearchRunAsync(Id, Auth.User!.Id);
            Nav.NavigateTo("/search");
        }
        catch
        {
            _deleting = false;
        }
    }

    private async Task HandleExportAll()
    {
        if (_run is null || !_canExport) return;

        _exporting = true;
        StateHasChanged();

        try
        {
            var csv = CsvExportService.ExportAll(_run.Keyword, _docs, _pains, _clusters, _allOpportunities);
            var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(csv)).ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var filename = $"queryradar-{_run.Keyword.Replace(" ", "-").ToLowerInvariant()}-{DateTime.UtcNow:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("downloadFile", filename, "text/csv", base64);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }
}
