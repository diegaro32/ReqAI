@page "/radar/{Id:guid}"

<AuthGuard>
    @if (_loading || _monitor is null)
    {
        <div class="flex items-center gap-3 text-txt-secondary">
            <div class="w-5 h-5 border-2 border-semantic-system/30 border-t-semantic-system rounded-full animate-spin"></div>
            <span>Cargando...</span>
        </div>
    }
    else
    {
        <div class="flex items-center gap-4 mb-6">
            <a href="/radar" class="text-txt-muted hover:text-semantic-highlight transition-colors">← Atrás</a>
            <h1 class="text-3xl font-bold text-txt-primary">@_monitor.Name</h1>
            <StatusBadge Status="@_monitor.Status" />
        </div>

        @* Monitor Stats *@
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6">
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Keyword</dt>
                <dd class="mt-1 text-lg font-mono font-semibold text-semantic-system">@_monitor.Keyword</dd>
            </div>
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Total de Escaneos</dt>
                <dd class="mt-1 text-2xl font-bold text-txt-primary">@_monitor.TotalScans</dd>
            </div>
            <div class="glass-card px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Documentos</dt>
                <dd class="mt-1 text-2xl font-bold text-txt-primary">@_monitor.TotalDocuments</dd>
            </div>
            <div class="glass-card glow-pain px-5 py-5">
                <dt class="text-[11px] font-semibold text-txt-muted uppercase tracking-wider">Señales Detectadas</dt>
                <dd class="mt-1 text-2xl font-bold text-semantic-pain">@_monitor.TotalPainsDetected</dd>
            </div>
        </div>

        @* Scan History *@
        <div class="glass-card p-6">
            <h2 class="text-[15px] font-semibold text-txt-primary mb-4">Historial de Escaneos</h2>
            @if (_scans.Count == 0)
            {
                <p class="text-txt-muted text-sm">Sin escaneos aún. El primer escaneo se ejecuta dentro de las 12 horas de crear el monitor.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-surface-border">
                        <thead>
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Iniciado</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Estado</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Docs</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Señales</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Duración</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-txt-muted uppercase tracking-wider">Consulta Expandida</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-surface-border">
                            @foreach (var scan in _scans)
                            {
                                var duration = scan.CompletedAt.HasValue
                                    ? $"{Math.Round((scan.CompletedAt.Value - scan.StartedAt).TotalSeconds)}s"
                                    : "—";
                                <tr class="hover:bg-surface-hover transition-colors">
                                    <td class="px-4 py-3 text-sm text-txt-primary">@scan.StartedAt.ToLocalTime().ToString()</td>
                                    <td class="px-4 py-3 text-sm"><StatusBadge Status="@scan.Status" /></td>
                                    <td class="px-4 py-3 text-sm text-txt-secondary">@scan.DocumentsCollected</td>
                                    <td class="px-4 py-3 text-sm text-txt-secondary">@scan.PainsDetected</td>
                                    <td class="px-4 py-3 text-sm text-txt-secondary">@duration</td>
                                    <td class="px-4 py-3 text-sm text-txt-muted max-w-xs truncate" title="@(scan.ExpandedQuery ?? "")">
                                        @(scan.ExpandedQuery is not null && scan.ExpandedQuery.Length > 80
                                            ? scan.ExpandedQuery[..80] + "..."
                                            : scan.ExpandedQuery ?? "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</AuthGuard>

@code {
    [Parameter] public Guid Id { get; set; }
    [Inject] private IRadarMonitorService RadarService { get; set; } = default!;
    [Inject] private AuthService Auth { get; set; } = default!;

    private RadarMonitorDto? _monitor;
    private List<RadarScanDto> _scans = [];
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _monitor = await RadarService.GetMonitorAsync(Id, Auth.User!.Id);
                _scans = (await RadarService.GetMonitorScansAsync(Id, Auth.User!.Id)).ToList();
            }
            catch { }
            finally { _loading = false; StateHasChanged(); }
        }
    }
}
