@page "/"
@layout LandingLayout
@inject NavigationManager Nav
@inject AuthService Auth

@* NAVBAR *@
<nav class="fixed top-0 left-0 right-0 z-50 bg-surface-bg/80 backdrop-blur-xl border-b border-surface-border/50">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
            <img src="/images/favicon.png" alt="ReqAI" class="h-8 object-contain" />
            <span class="text-[15px] font-bold text-txt-primary">ReqAI</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm text-txt-secondary">
            <a href="#como-funciona" class="hover:text-txt-primary transition-colors">Cómo Funciona</a>
            <a href="#resultados" class="hover:text-txt-primary transition-colors">Ver Resultados</a>
            <a href="#precios" class="hover:text-txt-primary transition-colors">Precios</a>
        </div>
        <div class="flex items-center gap-4">
            @if (Auth.User is not null)
            {
                <a href="/dashboard" class="btn-gradient rounded-xl px-4 py-2 text-sm font-semibold text-white">Ir al Dashboard</a>
            }
            else
            {
                <a href="/login" class="text-sm text-txt-secondary hover:text-txt-primary transition-colors hidden sm:block">Iniciar sesión</a>
                <a href="/register" class="btn-gradient rounded-xl px-4 py-2 text-sm font-semibold text-white">Empezar Gratis</a>
            }
        </div>
    </div>
</nav>

@* HERO *@
<section class="pt-32 pb-10 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-semantic-system/[0.06] via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute top-10 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full bg-semantic-system/[0.04] blur-[120px] pointer-events-none"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10 pt-10">
        <div class="inline-flex items-center gap-2 rounded-full border border-semantic-system/30 bg-semantic-system/5 px-4 py-1.5 text-[11px] font-semibold text-semantic-system uppercase tracking-widest mb-8">
            Análisis de requerimientos con IA
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-txt-primary leading-[1.08] tracking-tight">
            Para de adivinar<br />
            <span class="bg-gradient-to-r from-semantic-system via-semantic-opportunity to-semantic-highlight bg-clip-text text-transparent">qué quiso decir tu cliente.</span>
        </h1>
        <p class="mt-8 text-lg md:text-xl text-txt-secondary max-w-2xl mx-auto leading-relaxed">
            Pega la conversación. ReqAI extrae requerimientos estructurados, detecta reglas de negocio,
            identifica inconsistencias y te dice quién debe decidir qué — antes de escribir una sola línea de código.
        </p>
        <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/register" class="btn-gradient rounded-2xl px-10 py-4 text-base font-bold text-white">
                Analizar mi primera conversación →
            </a>
            <a href="#resultados" class="rounded-2xl border border-surface-border/60 px-10 py-4 text-base font-medium text-txt-secondary hover:text-txt-primary hover:border-surface-border hover:bg-surface-hover/30 transition-all">
                Ver qué obtienes ↓
            </a>
        </div>
        <p class="mt-5 text-xs text-txt-muted">Sin tarjeta de crédito · 3 análisis gratis · Resultado en segundos</p>
    </div>
</section>

@* PRODUCT PREVIEW *@
<section class="pb-20 px-6">
    <div class="max-w-5xl mx-auto">
        <div class="rounded-3xl border border-surface-border/50 bg-surface-card/40 p-2 shadow-2xl shadow-black/30">
            <div class="rounded-xl bg-surface-bg/80 border border-surface-border/30 p-6 space-y-4">
                <div class="flex items-center gap-3 pb-4 border-b border-surface-border/30">
                    <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-semantic-pain/60"></div>
                        <div class="w-3 h-3 rounded-full bg-semantic-cluster/60"></div>
                        <div class="w-3 h-3 rounded-full bg-semantic-opportunity/60"></div>
                    </div>
                    <span class="text-xs text-txt-muted font-mono ml-3">ReqAI — Análisis de Requerimientos</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    @foreach (var card in _mockOutputCards)
                    {
                        <div class="rounded-xl bg-surface-card/60 border @card.BorderClass p-4 space-y-2">
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] font-bold @card.LabelClass uppercase tracking-wider">@card.Section</span>
                            </div>
                            <ul class="space-y-1.5">
                                @foreach (var item in card.Items)
                                {
                                    <li class="flex items-start gap-1.5 text-[11px] text-txt-secondary leading-relaxed">
                                        <span class="@card.DotClass shrink-0 mt-0.5">•</span>@item
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@* TRUST BAR *@
<section class="py-16 px-6 border-y border-surface-border/30">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 text-center">
        @foreach (var stat in _stats)
        {
            <div>
                <div class="text-2xl md:text-3xl font-bold text-txt-primary">@stat.Value</div>
                <div class="text-xs text-txt-muted mt-1">@stat.Label</div>
            </div>
        }
    </div>
</section>

@* PROBLEM *@
<section class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">Los proyectos no fallan en el código.<br />Fallan en la conversación anterior.</h2>
            <p class="mt-4 text-lg text-txt-secondary max-w-xl mx-auto">
                El cliente dijo una cosa. Tú entendiste otra. El equipo interpretó una tercera. Tres semanas después, nadie sabe por qué nada encaja.
            </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var pain in _problems)
            {
                <div class="rounded-2xl border border-semantic-pain/15 bg-semantic-pain/[0.03] p-7 flex items-start gap-4">
                    <span class="text-semantic-pain text-lg shrink-0 mt-0.5">✗</span>
                    <div>
                        <h3 class="text-[15px] font-semibold text-txt-primary mb-1.5">@pain.Title</h3>
                        <p class="text-sm text-txt-secondary leading-relaxed">@pain.Description</p>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-10">
            <p class="text-sm text-txt-secondary mb-5">Cada semana que arrancas sin claridad es una semana de retrabajo garantizado.</p>
            <a href="/register" class="btn-gradient inline-block rounded-xl px-6 py-2.5 text-sm font-semibold text-white">Empieza con claridad</a>
        </div>
    </div>
</section>

@* SOLUTION *@
<section class="py-28 px-6 bg-gradient-to-b from-transparent via-surface-card/20 to-transparent">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
            <span class="text-[11px] font-bold text-semantic-opportunity uppercase tracking-widest">La solución</span>
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary mt-3">Conversación sucia →<br />Especificación lista para construir.</h2>
            <p class="mt-4 text-lg text-txt-secondary max-w-2xl mx-auto">
                No es un resumen. No es un chatbot. ReqAI actúa como un arquitecto senior que lee entre líneas,
                detecta lo que falta y estructura todo en un documento que tu equipo puede usar desde mañana.
            </p>
        </div>
        <div class="glass-card p-8 border border-semantic-system/30 mt-10">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                @foreach (var step in _solutionSteps)
                {
                    <div class="text-center">
                        <div class="w-16 h-16 mx-auto rounded-3xl bg-semantic-system/10 border border-semantic-system/20 flex items-center justify-center text-2xl mb-5">@step.Icon</div>
                        <div class="text-[10px] font-bold text-semantic-system uppercase tracking-widest mb-2">@step.Label</div>
                        <h3 class="text-base font-semibold text-txt-primary mb-2.5">@step.Title</h3>
                        <p class="text-sm text-txt-secondary leading-relaxed">@step.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@* HOW IT WORKS *@
<section id="como-funciona" class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">De conversación a especificación.<br />En menos de 60 segundos.</h2>
            <p class="mt-4 text-lg text-txt-secondary">Sin plantillas. Sin trabajo manual. Solo pega y analiza.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            @foreach (var step in _pipelineSteps)
            {
                <div class="relative glass-card p-7 text-center border border-surface-border/40 hover:border-semantic-system/30 transition-colors group">
                    @if (step.Number < 4)
                    {
                        <div class="hidden md:block absolute -right-3.5 top-1/2 -translate-y-1/2 text-txt-muted/30 text-lg z-10">→</div>
                    }
                    <div class="w-12 h-12 mx-auto rounded-2xl bg-semantic-system/10 flex items-center justify-center text-xl mb-4 group-hover:bg-semantic-system/20 transition-colors">@step.Icon</div>
                    <div class="text-[10px] font-bold text-semantic-system/60 uppercase tracking-widest mb-1">Paso @step.Number</div>
                    <h3 class="text-sm font-semibold text-txt-primary mb-2">@step.Title</h3>
                    <p class="text-[12px] text-txt-secondary leading-relaxed">@step.Description</p>
                </div>
            }
        </div>
    </div>
</section>

@* WHAT YOU GET *@
<section id="resultados" class="py-28 px-6 bg-gradient-to-b from-transparent via-surface-card/20 to-transparent">
    <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">No es un resumen.<br /><span class="text-semantic-opportunity">Es un plan de construcción.</span></h2>
            <p class="mt-4 text-lg text-txt-secondary">Cada análisis incluye todo lo que un equipo necesita para empezar sin preguntas.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            @foreach (var value in _coreValues)
            {
                <div class="glass-card p-8 border border-surface-border/40 hover:border-surface-border/60 transition-colors flex gap-5">
                    <div class="w-12 h-12 shrink-0 rounded-2xl @value.ColorClass flex items-center justify-center text-xl">@value.Icon</div>
                    <div>
                        <h3 class="text-[15px] font-semibold text-txt-primary mb-2">@value.Title</h3>
                        <p class="text-sm text-txt-secondary leading-relaxed">@value.Description</p>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-10">
            <a href="/register" class="btn-gradient inline-block rounded-xl px-6 py-2.5 text-sm font-semibold text-white">Ver mi primer análisis — Gratis</a>
        </div>
    </div>
</section>

@* DIFFERENTIATION *@
<section class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">No es ChatGPT con un prompt bonito.<br /><span class="text-semantic-highlight">Es una herramienta de ingeniería.</span></h2>
        </div>
        <div class="glass-card p-8 border border-surface-border/40">
            <div class="grid grid-cols-3 gap-4 text-center mb-6">
                <div></div>
                <div class="text-[10px] font-bold text-txt-muted uppercase tracking-wider">ChatGPT / Resumen</div>
                <div class="text-[10px] font-bold text-semantic-system uppercase tracking-wider">ReqAI</div>
            </div>
            @foreach (var row in _comparisonRows)
            {
                <div class="grid grid-cols-3 gap-4 py-3 border-t border-surface-border/30 items-center">
                    <div class="text-sm text-txt-primary font-medium">@row.Label</div>
                    <div class="text-center text-sm text-txt-muted">@row.Manual</div>
                    <div class="text-center text-sm text-semantic-opportunity font-semibold">@row.QueryRadar</div>
                </div>
            }
        </div>
    </div>
</section>

@* WHO IT'S FOR *@
<section class="py-20 px-6 bg-gradient-to-b from-transparent via-surface-card/20 to-transparent">
    <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-txt-primary mb-10">Para quien construye software con clientes reales.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
            @foreach (var useCase in _useCases)
            {
                <div class="glass-card p-5 border border-surface-border/30 text-center">
                    <div class="text-2xl mb-2">@useCase.Icon</div>
                    <p class="text-sm text-txt-primary font-medium">@useCase.Title</p>
                    <p class="text-[11px] text-txt-muted mt-1">@useCase.Description</p>
                </div>
            }
        </div>
    </div>
</section>

@* PRICING CONTEXT *@
<section class="pt-20 pb-8 px-6">
    <div class="max-w-2xl mx-auto text-center">
        <p class="text-lg text-txt-secondary leading-relaxed">
            Un proyecto mal especificado cuesta en promedio <span class="text-semantic-pain font-semibold">30–40% más</span> en tiempo de desarrollo.
            Un análisis claro antes de empezar puede ahorrarte semanas.
        </p>
    </div>
</section>

@* PRICING *@
<section id="precios" class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">Precios simples. Empieza gratis.</h2>
            <p class="mt-4 text-lg text-txt-secondary">Escala cuando tu equipo lo necesite.</p>
        </div>
        <div class="flex items-center justify-center gap-3 mb-12">
            <span class="text-sm @(_annual ? "text-txt-muted" : "text-txt-primary font-semibold")">Mensual</span>
            <button @onclick="() => _annual = !_annual"
                    class="relative w-12 h-6 rounded-full transition-colors @(_annual ? "bg-semantic-system" : "bg-surface-border")">
                <div class="absolute top-0.5 w-5 h-5 rounded-full bg-white transition-transform @(_annual ? "translate-x-6" : "translate-x-0.5")"></div>
            </button>
            <span class="text-sm @(_annual ? "text-txt-primary font-semibold" : "text-txt-muted")">Anual</span>
            <span class="rounded-full bg-semantic-opportunity/15 text-semantic-opportunity px-2.5 py-0.5 text-[10px] font-bold">Ahorra 20%</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
            @foreach (var plan in _plans)
            {
                var isPopular = plan.Name == "Pro";
                var price = _annual ? plan.AnnualPrice : plan.MonthlyPrice;
                var effectiveMonthly = _annual ? Math.Round(plan.AnnualPrice / 12m, 0) : plan.MonthlyPrice;
                <div class="glass-card p-7 border @(isPopular ? "border-semantic-system/50 ring-1 ring-semantic-system/20" : "border-surface-border/40") relative flex flex-col">
                    @if (isPopular)
                    {
                        <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-semantic-system px-3 py-0.5 text-[10px] font-bold text-white uppercase tracking-wider">Más Popular</div>
                    }
                    <h3 class="text-base font-bold text-txt-primary">@plan.Name</h3>
                    <div class="mt-3 mb-1">
                        <span class="text-3xl font-bold text-txt-primary">$@effectiveMonthly</span>
                        <span class="text-sm text-txt-muted">/mo</span>
                    </div>
                    @if (_annual && plan.MonthlyPrice > 0)
                    {
                        <p class="text-[11px] text-semantic-opportunity mb-3">$@price facturado anualmente</p>
                    }
                    else
                    {
                        <p class="text-[11px] text-txt-muted mb-3">@(plan.MonthlyPrice == 0 ? "Gratis para siempre" : "Facturado mensualmente")</p>
                    }
                    <ul class="space-y-2 mb-6 flex-1">
                        @foreach (var feature in plan.Features)
                        {
                            <li class="flex items-start gap-2 text-xs text-txt-secondary">
                                <span class="text-semantic-opportunity mt-0.5 shrink-0">✓</span>@feature
                            </li>
                        }
                    </ul>
                    <a href="/register"
                       class="block text-center rounded-2xl py-3 text-sm font-semibold transition-all @(isPopular ? "btn-gradient" : "bg-surface-hover/60 text-txt-primary hover:bg-surface-hover border border-surface-border/60")">
                        @(plan.MonthlyPrice == 0 ? "Empezar Gratis" : "Empezar Prueba Gratis")
                    </a>
                </div>
            }
        </div>
    </div>
</section>

@* SOCIAL PROOF *@
<section class="py-28 px-6 bg-gradient-to-b from-transparent via-surface-card/20 to-transparent">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">Menos reuniones de "¿qué quisiste decir?".<br />Más código que funciona.</h2>
            <p class="mt-4 text-lg text-txt-secondary max-w-xl mx-auto">Equipos que usan ReqAI empiezan cada proyecto con un documento que todos entienden.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            @foreach (var proof in _socialProofs)
            {
                <div class="glass-card p-7 border border-surface-border/40">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-8 h-8 rounded-full bg-semantic-system/10 border border-semantic-system/20 flex items-center justify-center text-sm font-bold text-txt-secondary">@proof.Initials</div>
                        <div>
                            <p class="text-[12px] font-semibold text-txt-primary">@proof.Name</p>
                            <p class="text-[10px] text-txt-muted font-mono">@proof.Role</p>
                        </div>
                    </div>
                    <p class="text-[12px] text-txt-secondary leading-relaxed italic">"@proof.Quote"</p>
                </div>
            }
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="text-center glass-card p-4 border border-surface-border/30">
                <p class="text-[13px] font-semibold text-txt-primary mt-1">Requerimientos sin ambigüedad</p>
            </div>
            <div class="text-center glass-card p-4 border border-surface-border/30">
                <p class="text-[13px] font-semibold text-txt-primary mt-1">Análisis en segundos</p>
            </div>
            <div class="text-center glass-card p-4 border border-surface-border/30">
                <p class="text-[13px] font-semibold text-txt-primary mt-1">Sin tarjeta de crédito</p>
            </div>
            <div class="text-center glass-card p-4 border border-surface-border/30">
                <p class="text-[13px] font-semibold text-txt-primary mt-1">Listo para tu próximo proyecto</p>
            </div>
        </div>
    </div>
</section>

@* FINAL CTA *@
<section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center">
        <div class="glass-card p-14 border border-semantic-system/20 bg-gradient-to-br from-semantic-system/[0.06] to-transparent">
            <h2 class="text-3xl md:text-4xl font-bold text-txt-primary mb-4">Tu próxima reunión con el cliente<br />no debería terminar con dudas.</h2>
            <p class="text-lg text-txt-secondary mb-10 max-w-lg mx-auto">
                Pega la conversación. Obtén claridad total. Empieza a construir lo correcto desde el primer día.
            </p>
            <a href="/register" class="btn-gradient inline-block rounded-2xl px-10 py-4 text-base font-bold text-white">
                Analizar mi primera conversación — Gratis
            </a>
            <p class="mt-5 text-xs text-txt-muted">Sin tarjeta de crédito · 3 análisis gratis · Resultados en segundos</p>
        </div>
    </div>
</section>

@* FOOTER *@
<footer class="border-t border-surface-border/50 py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
            <img src="/images/favicon.png" alt="ReqAI" class="h-7 object-contain" />
            <span class="text-sm text-txt-muted">© @DateTime.UtcNow.Year ReqAI · Todos los derechos reservados.</span>
        </div>
        <div class="flex items-center gap-6 text-xs text-txt-muted">
            <a href="#como-funciona" class="hover:text-txt-secondary transition-colors">Cómo Funciona</a>
            <a href="#precios" class="hover:text-txt-secondary transition-colors">Precios</a>
            <a href="/login" class="hover:text-txt-secondary transition-colors">Iniciar sesión</a>
            <a href="/register" class="hover:text-txt-secondary transition-colors">Registrarse</a>
        </div>
    </div>
</footer>

@code {
    private bool _annual;

    private record SolutionStep(string Icon, string Label, string Title, string Description);
    private record PipelineStep(int Number, string Icon, string Title, string Description);
    private record CoreValue(string Icon, string Title, string Description, string ColorClass);
    private record PlanInfo(string Name, decimal MonthlyPrice, decimal AnnualPrice, List<string> Features);
    private record Problem(string Title, string Description);
    private record Stat(string Value, string Label);
    private record MockOutputCard(string Section, string[] Items, string BorderClass, string LabelClass, string DotClass);
    private record SocialProof(string Initials, string Name, string Role, string Quote);
    private record ComparisonRow(string Label, string Manual, string QueryRadar);
    private record UseCase(string Icon, string Title, string Description);

    private static readonly MockOutputCard[] _mockOutputCards =
    [
        new("Requerimientos Funcionales", [
            "El sistema deberá permitir crear una factura en menos de 30 segundos",
            "El sistema deberá enviar la factura por email con un clic",
            "El administrador podrá ver el historial de todas las facturas emitidas"
        ], "border-semantic-opportunity/25", "text-semantic-opportunity", "text-semantic-opportunity"),
        new("Inconsistencias Detectadas", [
            "El cliente menciona 'roles de admin' pero luego dice 'solo yo lo usaré' — ¿sistema multiusuario?",
            "Se habla de 'facturación recurrente' pero no se define frecuencia ni proceso de cancelación"
        ], "border-semantic-pain/25", "text-semantic-pain", "text-semantic-pain"),
        new("Puntos de Decisión", [
            "¿El sistema debe integrarse con pasarelas de pago o solo generar el documento?",
            "¿Se requiere multimoneda? El cliente mencionó 'clientes en el extranjero' sin especificar"
        ], "border-semantic-cluster/25", "text-semantic-cluster", "text-semantic-cluster"),
    ];

    private static readonly SolutionStep[] _solutionSteps =
