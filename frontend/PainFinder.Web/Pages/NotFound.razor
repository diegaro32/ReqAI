@page "/notfound"
@page "/{*path}"

<div class="flex flex-col items-center justify-center min-h-[60vh] gap-4">
    <div class="glass-card p-8 text-center max-w-md">
        <div class="text-5xl mb-4">🔍</div>
        <h1 class="text-2xl font-bold text-txt-primary mb-2">Página no encontrada</h1>
        <p class="text-txt-muted text-sm mb-6">La página que buscas no existe o ha sido movida.</p>
        <a href="/dashboard"
           class="inline-block rounded-lg bg-semantic-system px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#4F46E5] transition-colors">
            Ir al Dashboard
        </a>
    </div>
</div>

@code {
    [Parameter] public string? Path { get; set; }
}
