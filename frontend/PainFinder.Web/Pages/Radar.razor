@page "/radar"
@using PainFinder.Web.Models

<AuthGuard>
    <div class="mb-8">
        <h1 class="text-2xl font-semibold text-txt-primary">Radar de Dolor</h1>
        <p class="text-sm text-txt-muted mt-1">Monitoreo continuo de señales de dolor</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        @* Create Monitor Form *@
        <div class="lg:col-span-1">
            <div class="glass-card p-6 space-y-5">
                <div>
                    <label class="block text-[13px] font-medium text-txt-secondary mb-1.5">Nombre del Monitor</label>
                    <input type="text" @bind="_name"
                           placeholder="ej. Problemas de facturación freelance"
                           class="block w-full rounded-xl bg-surface-bg/80 border border-surface-border px-4 py-2.5 text-[13px] text-txt-primary placeholder:text-txt-muted focus:border-semantic-highlight focus:ring-1 focus:ring-semantic-highlight/50 focus:outline-none transition-all" />
                </div>

                <div>
                    <label class="block text-[13px] font-medium text-txt-secondary mb-1.5">Keyword a monitorear</label>
                    <div class="relative">
                        <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-txt-muted">
                            <Icon Name="radar" Size="18" StrokeWidth="1.5" />
                        </div>
                        <input type="text" @bind="_keyword"
                               placeholder="invoicing, billing, onboarding..."
                               class="block w-full rounded-xl bg-surface-bg/80 border border-surface-border pl-10 pr-4 py-3 text-[14px] text-txt-primary placeholder:text-txt-muted focus:border-semantic-highlight focus:ring-1 focus:ring-semantic-highlight/50 focus:outline-none transition-all" />
                    </div>
                </div>

                <SourceChipSelector @bind-Selected="_selectedSources" />

                <button type="button" @onclick="HandleCreate" disabled="@_loading"
                        class="btn-gradient w-full px-4 py-3 text-[14px] flex items-center justify-center gap-2">
                    @if (_loading)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                        <span>Creando...</span>
                    }
                    else
                    {
                        <Icon Name="radar" Size="16" StrokeWidth="1.5" />
                        <span>Crear Monitor</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="rounded-xl p-3 text-[13px] @(_message.StartsWith("✅") ? "bg-semantic-opportunity/10 text-semantic-opportunity" : _message.StartsWith("⚠") ? "bg-semantic-cluster/10 text-semantic-cluster" : "bg-semantic-pain/10 text-semantic-pain")">
                        @_message
                    </div>
                }
            </div>
        </div>

        @* Monitor List *@
        <div class="lg:col-span-2">
            <div class="glass-card p-6">
                <h2 class="text-[15px] font-semibold text-txt-primary mb-5">Monitores Activos</h2>
                @if (_monitors.Count == 0)
                {
                    <div class="text-center py-12">
                        <Icon Name="radar" Size="32" Class="text-txt-muted/50 mx-auto mb-3" StrokeWidth="1" />
                        <p class="text-txt-muted text-sm">Sin monitores aún. Crea uno para comenzar.</p>
                    </div>
                }
                else
                {
                    <div class="space-y-3">
                        @foreach (var m in _monitors)
                        {
                            var sources = m.Sources.Split(',', StringSplitOptions.TrimEntries);
                            var isActive = m.Status == "Active";

                            <div class="group relative rounded-xl bg-surface-card/80 p-4 transition-all duration-200 hover:bg-surface-hover/60">
                                @if (isActive)
                                {
                                    <div class="absolute top-0 left-0 right-0 h-[2px] rounded-t-xl bg-gradient-to-r from-semantic-system via-semantic-highlight to-semantic-system"></div>
                                }
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2.5 mb-1.5">
                                            <a href="/radar/@m.Id" class="font-semibold text-[14px] text-txt-primary hover:text-semantic-system transition-colors truncate">
                                                @m.Name
                                            </a>
                                            <StatusBadge Status="@m.Status" />
                                        </div>
                                        <div class="flex items-center gap-2 mb-2.5">
                                            <span class="text-[12px] font-mono text-semantic-highlight bg-semantic-highlight/8 px-2 py-0.5 rounded-md">
                                                @m.Keyword
                                            </span>
                                            <div class="flex items-center gap-0.5">
                                                @foreach (var s in sources.Take(4))
                                                {
                                                    <span class="w-5 h-5 rounded-md bg-surface-bg/60 flex items-center justify-center" title="@s">
                                                        <SourceIcon Name="@s" ShowLabel="false" Size="10" />
                                                    </span>
                                                }
                                                @if (sources.Length > 4)
                                                {
                                                    <span class="text-[10px] text-txt-muted ml-0.5">+@(sources.Length - 4)</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 text-[11px] text-txt-muted">
                                            <span class="flex items-center gap-1"><Icon Name="bar-chart-3" Size="12" /> @m.TotalScans escaneos</span>
                                            <span class="flex items-center gap-1"><Icon Name="file-text" Size="12" /> @m.TotalDocuments docs</span>
                                            <span class="flex items-center gap-1"><Icon Name="alert-triangle" Size="12" Class="text-semantic-pain/50" /> @m.TotalPainsDetected señales</span>
                                            @if (m.LastScanAt.HasValue)
                                            {
                                                <span class="flex items-center gap-1"><Icon Name="clock" Size="12" /> @m.LastScanAt.Value.ToLocalTime().ToShortDateString()</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-1 shrink-0 opacity-60 group-hover:opacity-100 transition-opacity">
                                        <a href="/radar/@m.Id"
                                           class="flex items-center gap-1 text-[11px] text-semantic-system bg-semantic-system/8 hover:bg-semantic-system/15 px-2.5 py-1.5 rounded-lg transition-colors">
                                            Detalles <Icon Name="arrow-right" Size="12" />
                                        </a>
                                        @if (m.Status == "Active")
                                        {
                                            <button @onclick="() => HandleAction(m.Id, Action.Pause)"
                                                    class="p-1.5 rounded-lg text-txt-muted hover:text-semantic-cluster hover:bg-semantic-cluster/8 transition-colors" title="Pause">
                                                <Icon Name="pause" Size="14" StrokeWidth="1.5" />
                                            </button>
                                        }
                                        @if (m.Status == "Paused")
                                        {
                                            <button @onclick="() => HandleAction(m.Id, Action.Resume)"
                                                    class="p-1.5 rounded-lg text-txt-muted hover:text-semantic-opportunity hover:bg-semantic-opportunity/8 transition-colors" title="Resume">
                                                <Icon Name="play" Size="14" StrokeWidth="1.5" />
                                            </button>
                                        }
                                        @if (m.Status != "Archived")
                                        {
                                            <button @onclick="() => HandleAction(m.Id, Action.Archive)"
                                                    class="p-1.5 rounded-lg text-txt-muted hover:text-txt-secondary hover:bg-surface-hover transition-colors" title="Archive">
                                                <Icon Name="archive" Size="14" StrokeWidth="1.5" />
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</AuthGuard>

@code {
    [Inject] private IRadarMonitorService RadarService { get; set; } = default!;
    [Inject] private AuthService Auth { get; set; } = default!;

    private List<RadarMonitorDto> _monitors = [];
    private string _name = "";
    private string _keyword = "";
    private List<string> _selectedSources = new(SourceData.AllSourceNames);
    private string _message = "";
    private bool _loading;

    private enum Action { Pause, Resume, Archive }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Refresh();
        }
    }

    private async Task Refresh()
    {
        if (Auth.User is null) return;
        try { _monitors = (await RadarService.GetAllMonitorsAsync(Auth.User.Id)).ToList(); }
        catch { }
        StateHasChanged();
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_keyword) || _selectedSources.Count == 0)
        {
            _message = "⚠️ Completa todos los campos y selecciona al menos una fuente.";
            return;
        }
        _loading = true;
        _message = "";
        try
        {
            await RadarService.CreateMonitorAsync(new CreateRadarMonitorRequest(
                _name.Trim(), _keyword.Trim(), _selectedSources), Auth.User!.Id);
            _message = "✅ ¡Monitor Radar creado! Escaneará automáticamente cada 12 horas.";
            _name = "";
            _keyword = "";
            await Refresh();
        }
        catch (Exception ex)
        {
            _message = $"❌ {ex.Message}";
        }
        finally { _loading = false; }
    }

    private async Task HandleAction(Guid id, Action action)
    {
        if (Auth.User is null) return;
        try
        {
            switch (action)
            {
                case Action.Pause: await RadarService.PauseMonitorAsync(id, Auth.User.Id); break;
                case Action.Resume: await RadarService.ResumeMonitorAsync(id, Auth.User.Id); break;
                case Action.Archive: await RadarService.ArchiveMonitorAsync(id, Auth.User.Id); break;
            }
            await Refresh();
        }
        catch { }
    }
}
