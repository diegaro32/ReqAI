@inherits LayoutComponentBase
@inject AuthService Auth

@if (_initialized)
{
    <div class="landing-glow"></div>
    <main class="min-h-screen relative z-10">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="glass-card p-6 m-4 border border-semantic-pain/30">
                    <h2 class="text-lg font-semibold text-semantic-pain mb-2">Something went wrong</h2>
                    <pre class="text-xs text-txt-muted whitespace-pre-wrap break-all max-h-[300px] overflow-y-auto">@ex.ToString()</pre>
                    <button @onclick="ResetError"
                            class="mt-4 rounded-lg bg-semantic-system px-4 py-2 text-sm font-semibold text-white hover:bg-[#4F46E5] transition-colors">
                        Try again
                    </button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
}
else
{
    <div class="flex items-center justify-center min-h-screen bg-surface-bg">
        <div class="flex flex-col items-center gap-4">
            <img src="/images/logo-queryradar.png" alt="QueryRadar" class="w-12 h-12 rounded-xl object-contain" />
            <div class="flex items-center gap-3 text-txt-secondary">
                <div class="w-5 h-5 border-2 border-semantic-system/30 border-t-semantic-system rounded-full animate-spin"></div>
                <span class="text-sm">Loading...</span>
            </div>
        </div>
    </div>
}

@code {
    private bool _initialized;
    private ErrorBoundary? _errorBoundary;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.InitializeAsync();
            _initialized = true;
            StateHasChanged();
        }
    }

    private void ResetError() => _errorBoundary?.Recover();
}
